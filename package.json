    "typecheck": "tsc"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
