  "description": "Verticy — bilans cliniques pour podologues, ostéopathes et kinésithérapeutes",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
